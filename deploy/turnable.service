[Unit]
Description=Turnable server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/etc/turnable
ExecStart=/usr/local/bin/turnable server -c /etc/turnable/config.json -s /etc/turnable/store.json
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
